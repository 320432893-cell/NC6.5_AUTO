[importlinter]
root_packages =
    core
    tools

[importlinter:contract:workflow_independence]
name = NC workflow modules stay independently wired
type = independence
modules =
    core.nc_pending_workflow
    core.nc_voucher_workflow
    core.nc_switch_generated_workflow
    core.nc_backfill_workflow

[importlinter:contract:core_no_reverse_tools]
name = core 不反依赖 tools(头号不变量;jab_probe/jab_environment 已下沉 core,无例外)
type = forbidden
source_modules =
    core
forbidden_modules =
    tools

[importlinter:contract:receipt_split_modules_no_entry_dep]
name = 收款单拆分模块不得反依赖入口 receipt_full_flow_entry(锁住拆分分层)
type = forbidden
source_modules =
    core.receipt_body_table_locator
    tools.receipt_business_memo_probe
    core.receipt_counterparty
    core.receipt_detail_async_verifier
    tools.receipt_detail_entry
    core.receipt_detail_fields
    core.receipt_detail_reader
    core.receipt_detail_report
    core.receipt_detail_row_cleanup
    core.receipt_detail_rows
    core.receipt_detail_screen_writer
    core.receipt_detail_writer
    tools.receipt_entry_check
    tools.receipt_finance_org_path_probe
    core.receipt_full_flow_test_prompts
    tools.receipt_header_diagnose
    core.receipt_keyboard_utils
    core.receipt_locator_cache
    core.receipt_modal_guard
    core.receipt_new_probe
    core.receipt_post_save_query
    tools.receipt_query_cli
    core.receipt_query_dynamic_fields
    core.receipt_query_fill
    core.receipt_query_guard
    core.receipt_query_match_reader
    core.receipt_query_page_reader
    core.receipt_query_pagination
    core.receipt_query_pagination_paths
    core.receipt_query_reader
    core.receipt_query_report
    core.receipt_query_result_tables
    core.receipt_query_window
    core.receipt_report
    core.receipt_row_stages
    core.receipt_save_cancel
    core.receipt_self_made_fill_trial
    tools.receipt_table_cell_probe
forbidden_modules =
    tools.receipt_full_flow_entry
